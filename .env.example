# Required
OPENROUTER_KEY=sk-or-v1-your-key-here

# App Configuration
APP_TITLE=Gombey AI
APP_FAVICON=/images/gombey_logo.png
CUSTOM_FOOTER=Built by Gombey Tech LLC

# Domains (update for production)
DOMAIN_CLIENT=https://chat.gombeytech.com
DOMAIN_SERVER=https://chat.gombeytech.com

# Security - Generate new values for production
# Use: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
CREDS_KEY=change-me-in-production-32-chars-long
CREDS_IV=change-me-in-production

# Authentication
ALLOW_REGISTRATION=false
ALLOW_EMAIL_LOGIN=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# Database
MONGO_URI=mongodb://mongodb:27017/GombeyAI

# Node Environment
NODE_ENV=production

# Config Path
CONFIG_PATH=librechat.yaml

# Host
HOST=0.0.0.0